{
  "name": "CartItem",
  "type": "object",
  "properties": {
    "product_id": {
      "type": "string",
      "description": "Reference to product"
    },
    "product_name": {
      "type": "string",
      "description": "Product name for display"
    },
    "product_image": {
      "type": "string",
      "description": "Product image URL"
    },
    "size": {
      "type": "string",
      "description": "Selected size"
    },
    "quantity": {
      "type": "number",
      "default": 1,
      "description": "Quantity"
    },
    "price": {
      "type": "number",
      "description": "Price per item"
    }
  },
  "required": [
    "product_id",
    "product_name",
    "price"
  ]
}